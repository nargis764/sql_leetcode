-- 1934. Confirmation Rate

WITH cte_1 AS (
    SELECT s.user_id, 
       s.time_stamp AS signup_timestamp,
       c.time_stamp AS confirmation_timestamp, c.action       
    FROM Signups s
    LEFT JOIN Confirmations c USING (user_id)
)
SELECT user_id,
       ROUND(SUM(CASE WHEN action= 'confirmed' THEN user_id ELSE 0 END)::NUMERIC/SUM(user_id), 2) AS confirmation_rate
FROM cte_1
GROUP BY user_id;
